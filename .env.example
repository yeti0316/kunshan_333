# ============================================================
# LLM API 配置（二选一即可）
# ============================================================

# 方式一：OpenAI 兼容接口
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini

# 方式二：DashScope（阿里云通义千问）
# DASHSCOPE_API_KEY=sk-your-dashscope-key
# LLM_MODEL=qwen-plus

# ============================================================
# OCR 服务配置（可选，默认本地加载 PaddleOCR）
# ============================================================

# OCR 模式: local | http
# local — 每次调用直接加载 PaddleOCR（简单，但每次启动慢几秒）
# http  — 连接常驻 OCR 服务（推荐，模型只加载一次）
# OCR_MODE=http
# OCR_SERVICE_URL=http://localhost:5000
